{
  "dependencies": {
    "@maptiler/sdk": "^3.11.1"
  },
  "name": "chokepointmonitor",
  "workspaces": [
    "frontend-svelte"
  ],
  "scripts": {
    "use:node": "nvm install && nvm use",
    "preinstall": "node -e \"const [maj,min]=process.versions.node.split('.').map(Number); if(maj<22 || (maj===22 && min<12)) { console.error('\\n❌ Node 22.12+ required. Current: '+process.versions.node+'\\n'); process.exit(1); }\"",
    "install:all": "pip install -r backend/requirements.txt && npm install",
    "dev:frontend": "npm run dev -w frontend-svelte",
    "dev:backend": "python -m backend.api.main",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "version": "1.0.0",
  "description": "Backend:      Install all required python packages using `pip install -r backend/requirements.txt`<br/>     To run, use command `python -m backend.api.main`",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samwilsonSW/ChokepointMonitor.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/samwilsonSW/ChokepointMonitor/issues"
  },
  "homepage": "https://github.com/samwilsonSW/ChokepointMonitor#readme",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "engineStrict": true
}
