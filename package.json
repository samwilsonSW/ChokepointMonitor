{
  "name": "chokepointmonitor",
  "version": "1.0.0",
  "type": "commonjs",
  "workspaces": [
    "frontend-svelte"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "engineStrict": true,
  "scripts": {
    "use:node": "nvm install && nvm use",
    "preinstall": "node -e \"const [maj,min]=process.versions.node.split('.').map(Number); if(maj<22 || (maj===22 && min<12)) { console.error('\\n❌ Node 22.12+ required. Current: '+process.versions.node+'\\n'); process.exit(1); }\"",
    "install:all": "pip install -r backend/requirements.txt && npm install",
    "dev:frontend": "npm run dev -w frontend-svelte",
    "dev:backend": "python -m backend.api.main",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "dependencies": {
    "@maptiler/sdk": "^3.11.1",
    "@skeletonlabs/skeleton": "^4.12.1",
    "@skeletonlabs/skeleton-svelte": "^4.12.1",
    "@tailwindcss/vite": "^4.2.1",
    "maplibre-gl": "^5.19.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "concurrently": "^9.2.1",
    "svelte": "^5.45.2",
    "vite": "^7.3.1"
  }
}
